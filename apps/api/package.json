{
  "name": "@siza/api",
  "version": "0.1.0",
  "private": true,
  "description": "Siza Express API with self-hosted MCP server and Gemini integration",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:mcp": "tsx watch src/mcp/index.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:mcp": "node dist/mcp/index.js",
    "test:mcp": "tsx test-mcp.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "jest --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "deploy": "wrangler deploy",
    "wrangler:dev": "wrangler dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@forgespace/siza-gen": "^0.13.2",
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.101.0",
    "@types/supertest": "^7.2.0",
    "array-flatten": "3.0.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "openai": "^6.33.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260329.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.5.0",
    "@types/ws": "^8.5.13",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^16.2.1",
    "eslint-config-prettier": "6.15.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  },
  "engines": {
    "node": ">=20"
  }
}
